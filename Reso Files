# ====================== Reso Transpiler ======================
def reso_transpile(code: str) -> str:
    """Basic .reso -> Python transpiler"""
    lines = code.split('\n')
    py_lines = ["# Transpiled from Reso", "from reso_forge import *", "forge = Forge()"]
    for line in lines:
        line = line.strip()
        if line.startswith("model "):
            name = line.split()[1].split('{')[0].strip()
            py_lines.append(f"{name} = IsingModel('/models/{name}', size=64)")
            py_lines.append(f"forge.mount('/models/{name}', {name})")
        elif "|" in line:
            py_lines.append(f"result = {line.replace('|', '| ')}")
        elif line.startswith("run on"):
            py_lines.append("# Hybrid target set")
    return "\n".join(py_lines)

